name: Sync Dev to UAT (Specific Repo Only)

on:
  push:
    branches:
      - master
    paths:
      - 'dev/**' # This "filters" the action so it ONLY runs if the 'dev' folder changes

jobs:
  copy-dev-to-uat:
    # This ensures it only runs in the specific repository you want
    if: github.repository == 'jaise-tj/jaise' 
    runs-on: ubuntu-latest
    permissions:
      contents: write 
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Copy dev content to uat
        run: |
          # 1. Create uat if missing
          mkdir -p uat
          
          # 2. Sync files (This only looks at the local 'dev' and 'uat' folders)
          cp -rf dev/* uat/
          
      - name: Commit and Push changes
        run: |
          git config --global user.name "github-actions[bot]"
          git config --global user.email "github-actions[bot]@users.noreply.github.com"
          
          git add uat/
          
          # Only push if there are actual changes
          if [ -n "$(git status --porcelain uat/)" ]; then
            git commit -m "Sync: Copy contents from dev to uat"
            git push
          else
            echo "No changes detected."
          fi
